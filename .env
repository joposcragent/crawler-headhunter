# Server
PORT=3000

# HH.ru
BASE_URL=https://hh.ru
HH_SEARCH_URL=https://hh.ru/search/vacancy?

# job-postings-crud
JOB_POSTINGS_CRUD_URL=http://localhost:8081

# Delay range between page navigations (milliseconds)
DELAY_MIN_MS=2000
DELAY_MAX_MS=17000

# Browser identity
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080
LOCALE=ru-RU
TIMEZONE=Europe/Moscow
NAVIGATOR_LANGUAGES=ru-RU,ru,en-US,en

BASE_URL = https://hh.ru
SELECTOR_VACANCY_LIST_PAGES_LINKS = ul[class^="magritte-number-pages-container"]>li>div>a
SELECTOR_VACANCY_LIST_CARDS = div[id][class^="vacancy-card"]
SELECTOR_VACANCY_LIST_CARD_TITLE = span[data-qa="serp-item__title-text"]
SELECTOR_VACANCY_LIST_CARD_COMPANY = span[data-qa="vacancy-serp__vacancy-employer-text"]
SELECTOR_VACANCY_CARD_CONTENT = div[data-qa="vacancy-description"]
